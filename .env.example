# Anthropic API key — you can also enter it in the app (Settings → Anthropic API key); the DB value takes priority over env.
ANTHROPIC_API_KEY=
# Optional: daemon bind (default 127.0.0.1:8787)
ROOKERY_HOST=127.0.0.1
ROOKERY_PORT=8787
# Optional: DB/state directory (default ~/.rookery)
ROOKERY_HOME=
# Optional: model overrides
ROOKERY_MASTER_MODEL=claude-opus-4-8
ROOKERY_WORKER_MODEL=claude-opus-4-8
# Workers can use a cheaper model (e.g. claude-sonnet-4-6) to cut cost.
# Optional: Slack adapter (if both are set, the daemon also brings up a Socket Mode bot).
# Entering tokens in the app (Settings > Slack) takes priority; these env values are the fallback (headless/CI).
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
# Slack cwd / allowed user ids / allow-all / usage refresh interval are now managed in the app settings (DB), not env.
# Optional: Linear integration API key (can also be entered in the app, Settings > Integrations — stored in the DB, takes priority over env).
ROOKERY_LINEAR_API_KEY=
