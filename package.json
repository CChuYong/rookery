{
  "name": "rookery",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "apps/desktop"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "rookery": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json && node -e \"try{require('fs').chmodSync('dist/index.js',0o755)}catch(e){}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:capabilities": "node scripts/smoke-capability-runtime.mjs",
    "smoke:capabilities:codex": "node scripts/smoke-capability-center-codex.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.7.3",
    "@slack/web-api": "^7.17.0",
    "better-sqlite3": "^12.11.1",
    "croner": "^10.0.1",
    "ws": "^8.21.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^3"
  }
}
