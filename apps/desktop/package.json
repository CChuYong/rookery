{
  "name": "@rookery/desktop",
  "productName": "Rookery",
  "version": "0.1.0",
  "description": "Rookery — mission control for an orchestrator agent with memory",
  "author": "CChuYonng",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "ROOKERY_NODE=\"$(node -p 'process.execPath')\" electron-vite dev",
    "build": "electron-vite build",
    "fetch-node": "node scripts/fetch-node.mjs",
    "build:mac": "node ../../scripts/gen-third-party-licenses.mjs && node scripts/fetch-node.mjs && node scripts/stage-daemon-deps.mjs && electron-vite build && electron-builder --mac --publish never",
    "build:linux": "node ../../scripts/gen-third-party-licenses.mjs && node scripts/fetch-node.mjs && node scripts/stage-daemon-deps.mjs && electron-vite build && electron-builder --linux --publish never",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "postinstall": "node scripts/fix-pty-perms.cjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@iconify-json/vscode-icons": "^1.2.58",
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@tanstack/react-virtual": "^3.14.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.21.0",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.1.0",
    "pretendard": "^1.3.9",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "32.3.3",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.6.0",
    "vitest": "^3"
  }
}
